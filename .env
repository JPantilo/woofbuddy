# PayPal Sandbox Credentials
# Get these from https://developer.paypal.com/
PAYPAL_MODE=sandbox
PAYPAL_CLIENT_ID=YOUR_SANDBOX_CLIENT_ID
PAYPAL_CLIENT_SECRET=YOUR_SANDBOX_CLIENT_SECRET
PAYPAL_RECEIVER_EMAIL=sb-xxxxxx@business.example.com

# Site URLs
# For local testing
PAYPAL_RETURN_URL=http://127.0.0.1:8000/payments/paypal/return/
PAYPAL_CANCEL_URL=http://127.0.0.1:8000/payments/paypal/cancel/
PAYPAL_NOTIFY_URL=http://127.0.0.1:8000/payments/paypal/notify/

# Update these when deploying to production
# PAYPAL_MODE=live
# PAYPAL_RETURN_URL=https://your-app.onrender.com/payments/paypal/return/
# PAYPAL_CANCEL_URL=https://your-app.onrender.com/payments/paypal/cancel/
# PAYPAL_NOTIFY_URL=https://your-app.onrender.com/payments/paypal/notify/
